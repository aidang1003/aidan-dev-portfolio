{
  "builds": [
    {
      "src": "portfolio/__init__.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/speedrun/:match*",
      "destination": "https://speedrun-eth-challenge-4-eta.vercel.app/speedrun-4/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/portfolio/__init__.py"
    }
  ]
}
