{
  "builds": [
    {
      "src": "portfolio/__init__.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/speedrun-4(/.*)?",
      "dest": "https://speedrun-eth-challenge-4-eta.vercel.app/$1"
    },
    {
      "src": "/(.*)",
      "dest": "portfolio/__init__.py"
    }
  ]
}
