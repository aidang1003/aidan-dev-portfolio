{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "rewrites": [
    {
      "source": "/aidan-develops/speedrun-4*",
      "destination": "https://aidan-develops.com/speedrun-4*"
    }
  ]
}
